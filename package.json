{
  "name": "youtube-to-social-media-short-cutter",
  "version": "1.0.0",
  "description": "A web application that converts long YouTube videos into short, engaging clips optimized for TikTok, Instagram Reels, and YouTube Shorts",
  "main": "server/server.js",
  "scripts": {
    "start": "node server/server.js",
    "dev": "nodemon server/server.js",
    "client": "cd client && npm start",
    "build": "npm run build:client && npm run build:server",
    "build:client": "cd client && npm run build",
    "build:server": "echo 'Server build completed'",
    "postinstall": "cd client && npm install"
  },
  "keywords": [
    "youtube",
    "video",
    "shorts",
    "tiktok",
    "instagram",
    "reels",
    "video-processing",
    "ai"
  ],
  "author": "Claude Code",
  "license": "MIT",
  "dependencies": {
    "@distube/ytdl-core": "^4.16.12",
    "axios": "^1.6.0",
    "cors": "^2.8.5",
    "dotenv": "^16.3.1",
    "express": "^4.18.2",
    "express-rate-limit": "^7.1.5",
    "ffmpeg-static": "^5.2.0",
    "fluent-ffmpeg": "^2.1.2",
    "helmet": "^7.1.0",
    "multer": "^1.4.5-lts.1",
    "platform": "^1.3.6",
    "python-shell": "^5.0.0",
    "sharp": "^0.32.6",
    "socket.io": "^4.7.2",
    "uuid": "^9.0.1",
    "ytdl-core": "^4.11.5"
  },
  "devDependencies": {
    "nodemon": "^3.0.1"
  }
}
